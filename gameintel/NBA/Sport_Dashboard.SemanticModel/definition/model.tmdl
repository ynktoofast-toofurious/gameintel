model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["nba_players","match_schedule","Players Profile","Match by Team","Teams","Full Roster"]

annotation PBI_ProTooling = ["DevMode"]

ref table nba_players
ref table match_schedule
ref table 'Players Profile'
ref table 'Match by Team'
ref table Teams
ref table 'Full Roster'

ref cultureInfo en-US

