	partition 'Match by Team' = m
		mode: directQuery
		source =
				let
				    Source = Sql.Database("ROME", "REMUS", [Query="SELECT#(lf)      'Home' AS Team_Side#(lf)    , ms.[game_key]#(lf)    , ms.[game_id]#(lf)    , ms.[game_date]#(lf)    , ms.[game_time]#(lf)    , ms.[home_team] AS Team#(lf)    , home_t.[team_id]      AS nba_team_id#(lf)    , home_logo.[logo_url]  AS Team_logo_url#(lf)    , ms.[matchup]#(lf)    , ms.[game_status]#(lf)    , ms.[home_score]       AS score#(lf)    , ms.[final_score]#(lf)    , ms.[is_current]#(lf)    , ms.[valid_from]#(lf)    , ms.[valid_to]#(lf)    , ms.[load_datetime]#(lf)    , CASE#(lf)        WHEN ms.[home_score] IS NULL OR ms.[away_score] IS NULL THEN NULL#(lf)        WHEN UPPER(ms.[game_status]) NOT IN ('FINAL', 'COMPLETED') THEN NULL#(lf)        WHEN ms.[home_score] > ms.[away_score] THEN 'W'#(lf)        WHEN ms.[home_score] < ms.[away_score] THEN 'L'#(lf)        ELSE 'T'#(lf)      END AS result#(lf)    , CASE#(lf)        WHEN UPPER(ms.[game_status]) IN ('LIVE', 'IN PROGRESS', 'HALFTIME') THEN 'Live'#(lf)        WHEN CAST(ms.[game_date] AS DATE) = CAST(GETDATE() AS DATE) THEN 'Today'#(lf)        WHEN CAST(ms.[game_date] AS DATE) = DATEADD(DAY, 1, CAST(GETDATE() AS DATE)) THEN 'Tomorrow'#(lf)        WHEN CAST(ms.[game_date] AS DATE) = DATEADD(DAY, -1, CAST(GETDATE() AS DATE)) THEN 'Yesterday'#(lf)        WHEN CAST(ms.[game_date] AS DATE) BETWEEN CAST(GETDATE() AS DATE) AND DATEADD(DAY, 7, CAST(GETDATE() AS DATE)) THEN 'Next 7 Days'#(lf)        WHEN CAST(ms.[game_date] AS DATE) < CAST(GETDATE() AS DATE) THEN 'Past'#(lf)        WHEN CAST(ms.[game_date] AS DATE) > CAST(GETDATE() AS DATE) THEN 'Future'#(lf)        ELSE 'Unknown'#(lf)      END AS game_time_bucket#(lf)FROM [REMUS].[dbo].[match_schedule] ms#(lf)LEFT JOIN [REMUS].[dbo].[nba_teams] home_t#(lf)    ON home_t.[team_name] = CASE#(lf)                                WHEN ms.[home_team] = 'Los Angeles Clippers' THEN 'LA Clippers'#(lf)                                ELSE ms.[home_team]#(lf)                            END#(lf)   AND home_t.[is_current] = 1#(lf)LEFT JOIN [REMUS].[dbo].[nba_team_logos] home_logo#(lf)    ON home_logo.[team_id] = home_t.[team_id]#(lf)#(lf)UNION ALL#(lf)#(lf)SELECT#(lf)      'Away' AS Team_Side#(lf)    , ms.[game_key]#(lf)    , ms.[game_id]#(lf)    , ms.[game_date]#(lf)    , ms.[game_time]#(lf)    , ms.[away_team]        AS Team#(lf)    , away_t.[team_id]      AS nba_team_id#(lf)    , away_logo.[logo_url]  AS Team_logo_url#(lf)    , ms.[matchup]#(lf)    , ms.[game_status]#(lf)    , ms.[away_score]       AS score#(lf)    , ms.[final_score]#(lf)    , ms.[is_current]#(lf)    , ms.[valid_from]#(lf)    , ms.[valid_to]#(lf)    , ms.[load_datetime]#(lf)    , CASE#(lf)        WHEN ms.[home_score] IS NULL OR ms.[away_score] IS NULL THEN NULL#(lf)        WHEN UPPER(ms.[game_status]) NOT IN ('FINAL', 'COMPLETED') THEN NULL#(lf)        WHEN ms.[away_score] > ms.[home_score] THEN 'W'#(lf)        WHEN ms.[away_score] < ms.[home_score] THEN 'L'#(lf)        ELSE 'T'#(lf)      END AS result#(lf)    , CASE#(lf)        WHEN UPPER(ms.[game_status]) IN ('LIVE', 'IN PROGRESS', 'HALFTIME') THEN 'Live'#(lf)        WHEN CAST(ms.[game_date] AS DATE) = CAST(GETDATE() AS DATE) THEN 'Today'#(lf)        WHEN CAST(ms.[game_date] AS DATE) = DATEADD(DAY, 1, CAST(GETDATE() AS DATE)) THEN 'Tomorrow'#(lf)        WHEN CAST(ms.[game_date] AS DATE) = DATEADD(DAY, -1, CAST(GETDATE() AS DATE)) THEN 'Yesterday'#(lf)        WHEN CAST(ms.[game_date] AS DATE) BETWEEN CAST(GETDATE() AS DATE) AND DATEADD(DAY, 7, CAST(GETDATE() AS DATE)) THEN 'Next 7 Days'#(lf)        WHEN CAST(ms.[game_date] AS DATE) < CAST(GETDATE() AS DATE) THEN 'Past'#(lf)        WHEN CAST(ms.[game_date] AS DATE) > CAST(GETDATE() AS DATE) THEN 'Future'#(lf)        ELSE 'Unknown'#(lf)      END AS game_time_bucket#(lf)FROM [REMUS].[dbo].[match_schedule] ms#(lf)LEFT JOIN [REMUS].[dbo].[nba_teams] away_t#(lf)    ON away_t.[team_name] = CASE#(lf)                                WHEN ms.[away_team] = 'Los Angeles Clippers' THEN 'LA Clippers'#(lf)                                ELSE ms.[away_team]#(lf)                            END#(lf)   AND away_t.[is_current] = 1#(lf)LEFT JOIN [REMUS].[dbo].[nba_team_logos] away_logo#(lf)    ON away_logo.[team_id] = away_t.[team_id]"])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

