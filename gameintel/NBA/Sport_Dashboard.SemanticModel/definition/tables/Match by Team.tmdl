table 'Match by Team'
	lineageTag: fa339670-d190-488a-b1e6-02157df8a811

	measure 'PP Away' = CALCULATE(MIN('Players Profile'[image_url]),'Match by Team'[Team_Side]="Away")
		lineageTag: f764b3fc-c6d5-4126-a97d-46999c77fe7c

	measure 'PP Home' = CALCULATE(MIN('Players Profile'[image_url]),'Match by Team'[Team_Side]="Home")
		lineageTag: c0193999-c351-42a0-8f01-579f341d33b2

	measure 'Total Games' = DISTINCTCOUNT('Match by Team'[game_key])
		formatString: #,0
		lineageTag: a1b2c3d4-e5f6-a7b8-c9d0-e1f2a3b4c5d6

	measure Wins = CALCULATE(COUNTROWS('Match by Team'), 'Match by Team'[result] = "W")
		formatString: #,0
		lineageTag: b2c3d4e5-f6a7-b8c9-d0e1-f2a3b4c5d6e7

	measure Losses = CALCULATE(COUNTROWS('Match by Team'), 'Match by Team'[result] = "L")
		formatString: #,0
		lineageTag: c3d4e5f6-a7b8-c9d0-e1f2-a3b4c5d6e7f8

	measure 'Win Pct' =
			VAR _W = [Wins]
			VAR _L = [Losses]
			RETURN DIVIDE(_W, _W + _L, 0)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: d4e5f6a7-b8c9-d0e1-f2a3-b4c5d6e7f8a9

	measure 'Avg Score' = AVERAGE('Match by Team'[score])
		formatString: #,0.0
		lineageTag: e5f6a7b8-c9d0-e1f2-a3b4-c5d6e7f8a9b0

	measure 'Home Wins' = CALCULATE([Wins], 'Match by Team'[Team_Side] = "Home")
		formatString: #,0
		lineageTag: f6a7b8c9-d0e1-f2a3-b4c5-d6e7f8a9b0c1

	measure 'Away Wins' = CALCULATE([Wins], 'Match by Team'[Team_Side] = "Away")
		formatString: #,0
		lineageTag: a7b8c9d0-e1f2-a3b4-c5d6-e7f8a9b0c1d2

	measure 'Home Win Pct' =
			VAR _HomeTotal = CALCULATE(COUNTROWS('Match by Team'), 'Match by Team'[Team_Side] = "Home", 'Match by Team'[result] IN {"W", "L"})
			VAR _HomeW = CALCULATE(COUNTROWS('Match by Team'), 'Match by Team'[Team_Side] = "Home", 'Match by Team'[result] = "W")
			RETURN DIVIDE(_HomeW, _HomeTotal, 0)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: b8c9d0e1-f2a3-b4c5-d6e7-f8a9b0c1d2e3

	measure 'Away Win Pct' =
			VAR _AwayTotal = CALCULATE(COUNTROWS('Match by Team'), 'Match by Team'[Team_Side] = "Away", 'Match by Team'[result] IN {"W", "L"})
			VAR _AwayW = CALCULATE(COUNTROWS('Match by Team'), 'Match by Team'[Team_Side] = "Away", 'Match by Team'[result] = "W")
			RETURN DIVIDE(_AwayW, _AwayTotal, 0)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c9d0e1f2-a3b4-c5d6-e7f8-a9b0c1d2e3f4

	measure 'Avg Home Score' = CALCULATE(AVERAGE('Match by Team'[score]), 'Match by Team'[Team_Side] = "Home")
		formatString: #,0.0
		lineageTag: b4c5d6e7-f8a9-b0c1-d2e3-f4a5b6c7d8e9

	measure 'Avg Away Score' = CALCULATE(AVERAGE('Match by Team'[score]), 'Match by Team'[Team_Side] = "Away")
		formatString: #,0.0
		lineageTag: c5d6e7f8-a9b0-c1d2-e3f4-a5b6c7d8e9f0

	measure 'Max Score' = MAX('Match by Team'[score])
		formatString: #,0
		lineageTag: a3b4c5d6-e7f8-a9b0-c1d2-e3f4a5b6c7d8

	measure 'Total Teams' = DISTINCTCOUNT('Match by Team'[nba_team_id])
		formatString: #,0
		lineageTag: d0e1f2a3-b4c5-d6e7-f8a9-b0c1d2e3f4a5

	measure 'Total Players' = DISTINCTCOUNT(nba_players[nba_player_id])
		formatString: #,0
		lineageTag: e1f2a3b4-c5d6-e7f8-a9b0-c1d2e3f4a5b6

	measure 'Score Margin' = ABS(MIN(match_schedule[home_score]) - MIN(match_schedule[away_score]))
		formatString: #,0
		lineageTag: f2a3b4c5-d6e7-f8a9-b0c1-d2e3f4a5b6c7

